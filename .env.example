# Root extractor — used by `node index.js` (Google Places Text Search, server-side)
GOOGLE_MAPS_API_KEY=your_server_or_unrestricted_maps_key_here
INEGI_DENUE_TOKEN=your_inegi_denue_token_here

# ── Google Cloud (hola@voren.com.mx) — enable these on the SAME GCP project as Firebase (or link billing) ──
#
# Required APIs (APIs & Services → Library):
#   • Places API (New)     — Node: POST https://places.googleapis.com/v1/places:searchText
#                            (Field masks in src/extractors/googleMaps.js)
#
# Recommended: use a separate browser key in frontend/.env (VITE_GOOGLE_MAPS_API_KEY) with HTTP referrer
# restrictions, and restrict THIS key to "Places API (New)" only (optional: IP / no browser referrers).
