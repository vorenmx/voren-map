rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Keep in sync with frontend/src/auth/allowed-google-emails.json
    function isAllowedGoogleEmail() {
      return request.auth != null
        && request.auth.token.email != null
        && (
          request.auth.token.email.lower() == 'hola@voren.com.mx'
          || request.auth.token.email.lower() == 'alberto@voren.com.mx'
          || request.auth.token.email.lower() == 'andres@voren.com.mx'
        );
    }

    // Returns the userId stored on an existing document, defaulting to the
    // caller's uid when the field is absent (backward compat for pre-migration docs).
    function docOwner() {
      return resource.data.get('userId', request.auth.uid);
    }

    // Shop catalogue — read-only for authenticated users, never writable from client
    match /shops/{shopId} {
      allow read: if isAllowedGoogleEmail();
      allow write: if false;
    }

    // Visited stores — scoped to the owning user
    match /visited_stores/{docId} {
      allow read:   if isAllowedGoogleEmail();
      allow create: if isAllowedGoogleEmail() && request.resource.data.userId == request.auth.uid;
      allow update: if isAllowedGoogleEmail() && docOwner() == request.auth.uid;
      allow delete: if isAllowedGoogleEmail() && docOwner() == request.auth.uid;
    }

    // Saved places — scoped to the owning user
    match /saved_places/{placeId} {
      allow read:   if isAllowedGoogleEmail();
      allow create: if isAllowedGoogleEmail() && request.resource.data.userId == request.auth.uid;
      allow update: if isAllowedGoogleEmail() && docOwner() == request.auth.uid;
      allow delete: if isAllowedGoogleEmail() && docOwner() == request.auth.uid;
    }

    // Legacy shop_statuses collection — read-only; new writes blocked
    match /shop_statuses/{shopId} {
      allow read:  if isAllowedGoogleEmail();
      allow write: if false;
    }
  }
}
