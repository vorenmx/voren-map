# Firebase Web App config — get these from Firebase Console > Project Settings > Your apps
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Google Maps JavaScript API key — get from Google Cloud Console > APIs & Services > Credentials
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google Maps Map ID — required for Advanced Markers and vector map cloud styling
# Create at: Google Cloud Console > Google Maps Platform > Map Management
VITE_GOOGLE_MAPS_MAP_ID=your_map_id_here
