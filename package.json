  "description": "Extracts motorcycle repair and parts shop data from Google Maps and INEGI DENUE for all of Mexico",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
